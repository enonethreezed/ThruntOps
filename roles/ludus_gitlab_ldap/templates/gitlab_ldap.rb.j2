gitlab_rails['ldap_enabled'] = true
gitlab_rails['ldap_servers'] = YAML.load <<-EOS
  main:
    label: 'Active Directory'
    host: '{{ ludus_gitlab_ldap_host }}'
    port: {{ ludus_gitlab_ldap_port }}
    uid: 'sAMAccountName'
    bind_dn: '{{ ludus_gitlab_ldap_bind_dn }}'
    password: '{{ ludus_gitlab_ldap_bind_password }}'
    encryption: 'plain'
    verify_certificates: false
    active_directory: true
    base: '{{ ludus_gitlab_ldap_base }}'
    group_base: '{{ ludus_gitlab_ldap_group_base }}'
    admin_group: '{{ ludus_gitlab_ldap_admin_group }}'
    sync_ssh_keys: false
EOS
